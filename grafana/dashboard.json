    "panel-9": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "cowrie-mysql"
                    },
                    "group": "mysql",
                    "kind": "DataQuery",
                    "spec": {
                      "format": "table",
                      "rawQuery": true,
                      "rawSql": "SELECT a.src_ip, COALESCE(NULLIF(a.country, ''), 'Unknown') AS country, MIN(s.start_time) AS first_seen, MAX(s.start_time) AS last_seen, COUNT(DISTINCT s.session_id) AS sessions, COUNT(aa.attempt_id) AS login_attempts, SUM(CASE WHEN aa.is_success = 1 THEN 1 ELSE 0 END) AS successful_logins, ROUND(a.risk_score, 2) AS risk_score, COALESCE(a.cluster_group, -1) AS cluster_group FROM attackers a JOIN sessions s ON a.ip_id = s.ip_id LEFT JOIN auth_attempts aa ON s.session_id = aa.session_id WHERE $__timeFilter(s.start_time) AND a.src_ip = '112.134.162.209' GROUP BY a.ip_id, a.src_ip, a.country, a.risk_score, a.cluster_group ORDER BY last_seen DESC LIMIT 20"
                    },
                    "version": "v0"
