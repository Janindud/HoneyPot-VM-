                      "editorMode": "code",
                      "format": "time_series",
                      "rawQuery": true,
                      "rawSql": "SELECT $__timeGroupAlias(s.start_time, '5m'), COUNT(s.session_id) AS attacks FROM sessions s JOIN attackers a ON s.ip_id = a.ip_id WHERE $__timeFilter(s.start_time) AND a.src_ip = '112.134.162.209' GROUP BY 1 ORDER BY 1",
                      "sql": {
                        "columns": [
                          {
                            "parameters": [],
                            "type": "function"
                          }
                        ],
                        "groupBy": [
                          {
                            "property": {
                              "type": "string"
                            },
                            "type": "groupBy"
                          }
                        ],
                        "limit": 50
                      }
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
          }
        },
        "description": "Cowrie sessions grouped into 5 minute buckets using the selected dashboard time range.",
        "id": 1,
        "links": [],
