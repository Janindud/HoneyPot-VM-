    "panel-5": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "cowrie-mysql"
                    },
                    "group": "mysql",
                    "kind": "DataQuery",
                    "spec": {
                      "format": "table",
                      "rawQuery": true,
                      "rawSql": "SELECT CASE WHEN cluster_group = -1 THEN 'new_unprocessed' ELSE CONCAT('cluster_', cluster_group) END AS cluster_group, COUNT(ip_id) AS total_attackers, ROUND(AVG(risk_score), 2) AS avg_risk, ROUND(MIN(risk_score), 2) AS min_risk, ROUND(MAX(risk_score), 2) AS max_risk FROM attackers WHERE cluster_group IS NOT NULL AND src_ip = '112.134.162.209' GROUP BY cluster_group ORDER BY avg_risk DESC, total_attackers DESC"
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
          }
        },
        "description": "K-Means behavior groups. Cluster number is only a label; avg_risk shows the dangerous group. -1 means new/unprocessed.",
        "id": 5,
        "links": [],
        "title": "Risk Clusters",
